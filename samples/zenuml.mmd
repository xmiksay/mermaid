    title Login flow
    @Actor User
    @Boundary Page
    @Control Auth
    @Database DB
    User -> Page.login(name, pass) {
        Auth.verify(name, pass) {
            found = DB.query(name)
            if (found) {
                return token
            } else {
                return denied
            }
        }
        Page.render()
    }
